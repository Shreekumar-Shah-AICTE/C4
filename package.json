{
  "name": "wayfare",
  "version": "1.0.0",
  "private": true,
  "description": "Accessible, crowd-aware indoor wayfinding for stadium fans during major football tournaments.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dup": "jscpd src",
    "knip": "knip",
    "madge": "madge --circular --extensions ts,tsx src",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "mutation": "stryker run",
    "e2e": "playwright test",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run dup && npm run madge && npm run test:cov"
  },
  "dependencies": {
    "next": "15.5.20",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "9.13.0",
    "@playwright/test": "1.61.1",
    "@stryker-mutator/core": "8.6.0",
    "@stryker-mutator/vitest-runner": "8.6.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.8.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "@vitest/coverage-v8": "2.1.4",
    "eslint": "9.13.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-sonarjs": "2.0.4",
    "happy-dom": "15.8.0",
    "jscpd": "4.0.5",
    "knip": "5.36.1",
    "madge": "8.0.0",
    "prettier": "3.3.3",
    "typescript": "5.6.3",
    "typescript-eslint": "8.12.2",
    "vitest": "2.1.4",
    "vitest-axe": "0.1.0"
  },
  "overrides": {
    "postcss": "^8.5.19",
    "tmp": "^0.2.5"
  }
}
