# ---------------------------------------------------------------------------
# Wayfare environment template. Copy to `.env.local` and fill in real values.
# NEVER commit a populated .env file — only this template lives in the repo.
# ---------------------------------------------------------------------------

# Google Gemini API key used purely to phrase already-computed navigation
# steps into natural language. The application is fully functional WITHOUT a
# key: the deterministic core still computes every route and a templated
# fallback narrator produces directions offline.
GEMINI_API_KEY=

# Generative model used for narration. Defaults to a fast, low-cost model.
GEMINI_MODEL=gemini-1.5-flash
